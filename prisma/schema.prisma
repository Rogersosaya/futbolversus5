generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Game {
  id                    Int      @id
  name                  String
  description           String
  imageUrl              String
  availableDifficulties String[]

  matchRooms MatchRoom[]
}

/// The three kinds of unlockable cosmetic ("card", à la Clash Royale).
enum CollectibleKind {
  CREST // escudo de club
  AVATAR // avatar / caricatura del presidente
  STADIUM // estadio

  @@map("collectible_kind")
}

/// Rarity tier — drives the badge shown in the store.
enum Rarity {
  LEGEND
  EPIC
  RARE
  COMMON

  @@map("rarity")
}

/// A league level in the "Ruta de Ligas" (like a Clash Royale arena). The
/// player ascends through leagues as their club's market value grows, and each
/// league unlocks the collectibles tied to it.
model League {
  id          String @id @default(cuid())
  /// Short stable slug, e.g. "pe", "ar". Used by the UI and flag symbols.
  code        String @unique
  name        String
  /// Display country name, e.g. "Perú".
  country     String
  /// ISO-ish flag code used by the flag symbol sheet, e.g. "pe", "gb".
  countryCode String @map("country_code")
  imageUrl    String @map("image_url")
  /// 1-based progression order (1 = first/lowest league).
  tier        Int    @unique
  /// Market value (€M) the club must reach to enter this league.
  minMarketValue Int  @map("min_market_value")
  /// Market value (€M) at which the club ascends to the next league. Null for
  /// the top league (no ceiling).
  maxMarketValue Int? @map("max_market_value")

  createdAt DateTime @default(now()) @map("created_at")

  collectibles Collectible[]
  profiles     Profile[]

  @@map("leagues")
}

/// A signed-in player ("president"). Mirrors the Supabase `profiles` table
/// (rows are created by the `on_auth_user_created` trigger; `id` references
/// `auth.users`). Related to the league the club currently competes in.
model Profile {
  id            String   @id @db.Uuid
  presidentName String?  @map("president_name")
  country       String?
  avatarId      String?  @map("avatar_id")
  stadiumId     String?  @map("stadium_id")
  shieldId      String?  @map("shield_id")
  /// The club's value (€M) — drives league progression only.
  clubValue     Int      @default(0) @map("club_value")
  /// Spendable budget (€M) used to buy collectibles in the Mercado.
  clubFunds     Int      @default(0) @map("club_funds")
  budget        Int      @default(0)
  /// Career stats shown on the player card (lobby / club / friend cards).
  /// Updated later when the match system exists; start at sensible defaults.
  level         Int      @default(1)
  power         Int      @default(50)
  wins          Int      @default(0)
  played        Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @map("updated_at")

  leagueId String? @map("league_id")
  league   League? @relation(fields: [leagueId], references: [id], onDelete: SetNull)

  /// Every collectible this player owns (their "colección"). The avatarId /
  /// stadiumId / shieldId above point to the one of each kind currently active.
  owned OwnedCollectible[]

  /// Friendships and friend requests (social graph).
  sentRequests     FriendRequest[] @relation("SentRequests")
  receivedRequests FriendRequest[] @relation("ReceivedRequests")
  friendshipsA     Friendship[]    @relation("FriendshipsA")
  friendshipsB     Friendship[]    @relation("FriendshipsB")

  /// Friendly-match rooms and invites.
  hostedRooms         MatchRoom[]   @relation("HostedRooms")
  joinedRooms         MatchRoom[]   @relation("JoinedRooms")
  sentMatchInvites    MatchInvite[] @relation("SentMatchInvites")
  receivedMatchInvites MatchInvite[] @relation("ReceivedMatchInvites")

  @@index([leagueId])
  @@map("profiles")
}

/// A cosmetic the player can unlock/buy in the Mercado. Becomes available once
/// the player reaches the league it belongs to. Starter collectibles are also
/// offered during first-login profile setup.
model Collectible {
  id          String          @id @default(cuid())
  kind        CollectibleKind
  name        String
  /// Maps to a built-in vector art / CSS modifier (e.g. "veteran", "crest-rma",
  /// "coliseo"). Null when the art is a raster image instead.
  artKey      String?         @map("art_key")
  /// Optional raster image (e.g. a stadium photo).
  imageUrl    String?         @map("image_url")
  /// Optional 2-stop gradient for generated tiles (stadiums without a photo).
  gradientFrom String?        @map("gradient_from")
  gradientTo   String?        @map("gradient_to")
  rarity      Rarity          @default(COMMON)
  /// Price in coins. 0 = free starter pick.
  price       Int             @default(0)
  /// Whether this is offered as an option during first-login profile setup.
  isStarter   Boolean         @default(false) @map("is_starter")
  /// Ordering within its (league, kind) group.
  sortOrder   Int             @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  leagueId String @map("league_id")
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  owners OwnedCollectible[]

  @@index([leagueId])
  @@index([kind])
  @@map("collectibles")
}

/// Ownership ledger: which collectibles a player has acquired (bought in the
/// Mercado or granted as free starter picks during profile setup). Separate
/// from "equipped" — a player owns many of each kind but only one is active
/// (Profile.avatarId / stadiumId / shieldId).
model OwnedCollectible {
  id            String   @id @default(cuid())
  profileId     String   @map("profile_id") @db.Uuid
  collectibleId String   @map("collectible_id")
  acquiredAt    DateTime @default(now()) @map("acquired_at")

  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  collectible Collectible @relation(fields: [collectibleId], references: [id], onDelete: Cascade)

  @@unique([profileId, collectibleId])
  @@index([profileId])
  @@map("owned_collectibles")
}

/// Lifecycle of a friendly-match room (lobby).
enum MatchRoomStatus {
  OPEN // waiting for a rival (seat free)
  READY // both seats taken — match found
  IN_GAME // entry cinematic finished — both players in the game room
  CLOSED // abandoned by the host / superseded
  FINISHED // played to completion (result screen)

  @@map("match_room_status")
}

/// A persistent friendly-match room. Exactly two seats: the host (creator) and
/// one guest. Created when the host presses JUGAR on /amistoso; the short
/// `code` is the URL slug (/jugar/amistoso/ABC123) and the invite-link token.
/// Access is restricted to host + guest; a third player can only take the
/// guest seat while it is free (first click wins, claimed atomically).
model MatchRoom {
  id         String          @id @default(cuid())
  /// Short shareable code, e.g. "K7M2QF". Unique across all rooms.
  code       String          @unique
  status     MatchRoomStatus @default(OPEN)
  /// Minigame + difficulty chosen by the host on /amistoso.
  gameId     Int?            @map("game_id")
  difficulty String?
  /// Match duration in seconds chosen by the host; 0 = no time limit.
  durationS  Int             @default(120) @map("duration_s")
  hostId     String          @map("host_id") @db.Uuid
  guestId    String?         @map("guest_id") @db.Uuid
  /// Server timestamp stamped when both players are present in the READY
  /// lobby. Single shared anchor both clients derive the synchronized
  /// match-entry cinematic from. Cleared if the guest leaves before kickoff.
  readyAt    DateTime?       @map("ready_at")
  /// Server timestamp of the READY → IN_GAME promotion (first player landing
  /// in the game room after the cinematic).
  startedAt  DateTime?       @map("started_at")
  /// "Once Mundialista" deck: national_team_ids shuffled once at the IN_GAME
  /// promotion. Both seats walk the SAME ordered cycle independently
  /// (active nation = nationCycle[idx % length]).
  nationCycle       Int[]     @default([]) @map("nation_cycle")
  hostNationIdx     Int       @default(0) @map("host_nation_idx")
  guestNationIdx    Int       @default(0) @map("guest_nation_idx")
  /// Nation-change penalty: claims blocked and next nation hidden until then.
  hostPenaltyUntil  DateTime? @map("host_penalty_until")
  guestPenaltyUntil DateTime? @map("guest_penalty_until")
  /// Server timestamp of the IN_GAME → FINISHED promotion.
  finishedAt        DateTime? @map("finished_at")
  /// Rematch handshake (FINISHED rooms only): each seat stamps its request;
  /// when both are stamped a fresh room is created and its code published
  /// here exactly once — both clients follow it to the new match.
  hostRematchAt     DateTime? @map("host_rematch_at")
  guestRematchAt    DateTime? @map("guest_rematch_at")
  rematchCode       String?   @map("rematch_code")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @default(now()) @map("updated_at")

  game  Game?    @relation(fields: [gameId], references: [id], onDelete: SetNull)
  host  Profile  @relation("HostedRooms", fields: [hostId], references: [id], onDelete: Cascade)
  guest Profile? @relation("JoinedRooms", fields: [guestId], references: [id], onDelete: SetNull)

  invites MatchInvite[]
  claims  MatchClaim[]

  @@index([hostId, status])
  @@index([guestId])
  @@map("match_rooms")
}

/// Lifecycle of a match invite (room owner → friend).
enum MatchInviteStatus {
  PENDING
  ACCEPTED
  DECLINED // receiver pressed ✗
  CANCELLED // sender pressed X
  EXPIRED // seat taken by someone else / room closed

  @@map("match_invite_status")
}

/// An invitation to join a match room, sent by the host to a friend. Both
/// sides render it as a floating notification in real time (Postgres Changes).
/// One row per (room, receiver); re-inviting revives a declined row.
model MatchInvite {
  id          String            @id @default(cuid())
  roomId      String            @map("room_id")
  senderId    String            @map("sender_id") @db.Uuid
  receiverId  String            @map("receiver_id") @db.Uuid
  status      MatchInviteStatus @default(PENDING)
  createdAt   DateTime          @default(now()) @map("created_at")
  respondedAt DateTime?         @map("responded_at")

  room     MatchRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender   Profile   @relation("SentMatchInvites", fields: [senderId], references: [id], onDelete: Cascade)
  receiver Profile   @relation("ReceivedMatchInvites", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([roomId, receiverId])
  @@index([receiverId, status])
  @@index([senderId, status])
  @@map("match_invites")
}

/// One claimed cell of the shared 22-cell "Once Mundialista" board. The unique
/// constraints settle races: first valid claim wins the cell, and a footballer
/// can appear at most once per board. A player's score is the COUNT of their
/// claims — derived, never stored.
model MatchClaim {
  id        String   @id @default(cuid())
  roomId    String   @map("room_id")
  /// Board cell id from src/data/gameboard.ts (e.g. "l-gk", "r-f2").
  cellId    String   @map("cell_id")
  playerId  Int      @map("player_id")
  claimedBy String   @map("claimed_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  room   MatchRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  player FutPlayer @relation(fields: [playerId], references: [playerId])

  @@unique([roomId, cellId])
  @@unique([roomId, playerId])
  @@index([roomId])
  @@map("match_claims")
}

/// Lifecycle of a friend request between two presidents.
enum FriendRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED

  @@map("friend_request_status")
}

/// A pending/resolved friend request. One direction (sender → receiver).
/// Becomes a Friendship row once accepted.
model FriendRequest {
  id          String              @id @default(cuid())
  senderId    String              @map("sender_id") @db.Uuid
  receiverId  String              @map("receiver_id") @db.Uuid
  status      FriendRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now()) @map("created_at")
  respondedAt DateTime?           @map("responded_at")

  sender   Profile @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver Profile @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@map("friend_requests")
}

/// An accepted friendship, stored once with a canonical ordering
/// (userAId < userBId) so a pair never appears twice.
model Friendship {
  id        String   @id @default(cuid())
  userAId   String   @map("user_a_id") @db.Uuid
  userBId   String   @map("user_b_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  userA Profile @relation("FriendshipsA", fields: [userAId], references: [id], onDelete: Cascade)
  userB Profile @relation("FriendshipsB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userBId])
  @@map("friendships")
}

// ============================================================
// FUTDB — datos de referencia para los minijuegos de fútbol
// (jugadores, clubes, competiciones, stats…). Solo lectura:
// se cargan vía supabase/migrations + \copy, nunca desde la app.
// ============================================================

model Country {
  countryPk     Int     @id @map("country_pk")
  countryName   String  @unique @map("country_name")
  /// id Transfermarkt (puede ser null)
  countryId     Int?    @map("country_id")
  confederation String?
  flagUrl       String? @map("flag_url")

  @@map("countries")
}

model Competition {
  /// ej. 'ES1', 'CL', 'GB1'
  competitionId      String  @id @map("competition_id")
  competitionCode    String? @map("competition_code")
  name               String
  subType            String? @map("sub_type")
  /// domestic_league | domestic_cup | international_cup
  type               String?
  countryId          Int?    @map("country_id")
  countryName        String? @map("country_name")
  domesticLeagueCode String? @map("domestic_league_code")
  confederation      String?
  totalClubs         Int?    @map("total_clubs")
  url                String?
  logoUrl            String? @map("logo_url")

  clubs       FutClub[]
  seasonStats PlayerSeasonStat[]
  playerLinks PlayerCompetition[]

  @@map("competitions")
}

/// Club de Transfermarkt ("Fut" para no chocar con los collectibles del juego).
model FutClub {
  clubId                Int      @id @map("club_id")
  clubCode              String?  @map("club_code")
  name                  String
  domesticCompetitionId String?  @map("domestic_competition_id")
  totalMarketValue      Decimal? @map("total_market_value")
  squadSize             Int?     @map("squad_size")
  averageAge            Decimal? @map("average_age")
  foreignersNumber      Int?     @map("foreigners_number")
  foreignersPercentage  Decimal? @map("foreigners_percentage")
  nationalTeamPlayers   Int?     @map("national_team_players")
  stadiumName           String?  @map("stadium_name")
  stadiumSeats          Int?     @map("stadium_seats")
  netTransferRecord     String?  @map("net_transfer_record")
  coachName             String?  @map("coach_name")
  lastSeason            Int?     @map("last_season")
  filename              String?
  url                   String?
  /// escudo: https://tmssl.akamaized.net/images/wappen/head/{club_id}.png
  logoUrl               String?  @map("logo_url")

  competition   Competition?   @relation(fields: [domesticCompetitionId], references: [competitionId])
  managerStints ManagerClub[]
  trophyWins    TrophyWinner[]
  stadiums      FutStadium[]

  @@map("clubs")
}

model NationalTeam {
  nationalTeamId       Int      @id @map("national_team_id")
  name                 String
  teamCode             String?  @map("team_code")
  countryId            Int?     @map("country_id")
  countryName          String?  @map("country_name")
  countryCode          String?  @map("country_code")
  confederation        String?
  /// bandera de la selección
  teamImageUrl         String?  @map("team_image_url")
  squadSize            Int?     @map("squad_size")
  averageAge           Decimal? @map("average_age")
  foreignersNumber     Int?     @map("foreigners_number")
  foreignersPercentage Decimal? @map("foreigners_percentage")
  totalMarketValue     Decimal? @map("total_market_value")
  coachName            String?  @map("coach_name")
  fifaRanking          Int?     @map("fifa_ranking")
  lastSeason           Int?     @map("last_season")
  url                  String?

  players     FutPlayer[]
  playerLinks PlayerNationalTeam[]

  @@map("national_teams")
}

/// Jugador de Transfermarkt (47K, foto en imageUrl con 100% de cobertura).
model FutPlayer {
  playerId                Int       @id @map("player_id")
  firstName               String?   @map("first_name")
  lastName                String?   @map("last_name")
  name                    String
  lastSeason              Int?      @map("last_season")
  /// Sin FK en la BD: ~2,269 juegan en clubes menores fuera de `clubs`
  /// (currentClub queda null para ellos; el nombre está en currentClubName).
  currentClubId           Int?      @map("current_club_id")
  playerCode              String?   @map("player_code")
  countryOfBirth          String?   @map("country_of_birth")
  cityOfBirth             String?   @map("city_of_birth")
  countryOfCitizenship    String?   @map("country_of_citizenship")
  dateOfBirth             DateTime? @map("date_of_birth") @db.Date
  subPosition             String?   @map("sub_position")
  position                String?
  foot                    String?
  heightInCm              Decimal?  @map("height_in_cm")
  contractExpirationDate  DateTime? @map("contract_expiration_date") @db.Date
  agentName               String?   @map("agent_name")
  /// foto oficial Transfermarkt
  imageUrl                String?   @map("image_url")
  internationalCaps       Int?      @map("international_caps")
  internationalGoals      Int?      @map("international_goals")
  currentNationalTeamId   Int?      @map("current_national_team_id")
  url                     String?
  currentClubDomesticCompetitionId String? @map("current_club_domestic_competition_id")
  currentClubName         String?   @map("current_club_name")
  marketValueInEur        Decimal?  @map("market_value_in_eur")
  highestMarketValueInEur Decimal?  @map("highest_market_value_in_eur")

  nationalTeam  NationalTeam?        @relation(fields: [currentNationalTeamId], references: [nationalTeamId])
  clubHistory   PlayerClub[]
  seasonStats   PlayerSeasonStat[]
  rosters       SeasonRoster[]
  competitions  PlayerCompetition[]
  nationalTeams PlayerNationalTeam[]
  transfers     Transfer[]
  awards        AwardWinner[]
  matchClaims   MatchClaim[]

  @@index([name])
  @@index([countryOfCitizenship])
  @@index([position, subPosition])
  @@map("players")
}

model Manager {
  managerId   Int       @id @map("manager_id")
  wikidataId  String?   @unique @map("wikidata_id")
  name        String
  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  nationality String?
  /// foto Wikimedia Commons (licencia libre)
  imageUrl    String?   @map("image_url")

  clubs ManagerClub[]

  @@map("managers")
}

/// Historial de equipos dirigidos (Wikidata).
model ManagerClub {
  id             BigInt    @id @default(autoincrement())
  managerId      Int?      @map("manager_id")
  /// null si el equipo no se pudo mapear a un club de Transfermarkt
  clubId         Int?      @map("club_id")
  teamName       String?   @map("team_name")
  teamWikidataId String?   @map("team_wikidata_id")
  startDate      DateTime? @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date

  manager Manager? @relation(fields: [managerId], references: [managerId])
  club    FutClub? @relation(fields: [clubId], references: [clubId])

  @@index([clubId])
  @@index([managerId])
  @@map("manager_clubs")
}

model FutStadium {
  stadiumId   Int     @id @map("stadium_id")
  stadiumName String  @map("stadium_name")
  capacity    Int?
  clubId      Int?    @map("club_id")
  clubName    String? @map("club_name")

  club FutClub? @relation(fields: [clubId], references: [clubId])

  @@map("stadiums")
}

model FutPosition {
  positionId Int     @id @map("position_id")
  nameEn     String? @map("name_en")
  nameEs     String? @map("name_es")
  code       String?
  category   String?

  @@map("positions")
}

model Formation {
  formationId Int     @id @map("formation_id")
  name        String
  /// lista de codes de posición separada por comas
  positions   String?

  @@map("formations")
}

model Award {
  awardId   Int     @id @map("award_id")
  name      String
  organizer String?
  since     Int?

  winners AwardWinner[]

  @@map("awards")
}

model Trophy {
  trophyId      Int     @id @map("trophy_id")
  name          String
  /// 'club' | 'international'
  scope         String?
  confederation String?

  winners TrophyWinner[]

  @@map("trophies")
}

/// Historial real de clubes por jugador (derivado de partidos jugados).
/// clubId sin FK: algunos clubes menores no están en `clubs`.
model PlayerClub {
  playerId    Int  @map("player_id")
  clubId      Int  @map("club_id")
  firstSeason Int? @map("first_season")
  lastSeason  Int? @map("last_season")
  matches     Int?
  goals       Int?
  assists     Int?
  minutes     Int?

  player FutPlayer @relation(fields: [playerId], references: [playerId])

  @@id([playerId, clubId])
  @@index([clubId])
  @@map("player_clubs")
}

/// La tabla más rica: jugador × club × temporada × competición.
model PlayerSeasonStat {
  playerId      Int    @map("player_id")
  clubId        Int    @map("club_id")
  season        Int
  competitionId String @map("competition_id")
  matches       Int?
  goals         Int?
  assists       Int?
  minutes       Int?
  yellowCards   Int?   @map("yellow_cards")
  redCards      Int?   @map("red_cards")

  player      FutPlayer   @relation(fields: [playerId], references: [playerId])
  competition Competition @relation(fields: [competitionId], references: [competitionId])

  @@id([playerId, clubId, season, competitionId])
  @@index([competitionId, season])
  @@map("player_season_stats")
}

/// Plantilla de cada club por temporada.
model SeasonRoster {
  clubId   Int @map("club_id")
  season   Int
  playerId Int @map("player_id")
  matches  Int?
  goals    Int?
  assists  Int?
  minutes  Int?

  player FutPlayer @relation(fields: [playerId], references: [playerId])

  @@id([clubId, season, playerId])
  @@index([playerId])
  @@map("season_rosters")
}

/// En qué competiciones jugó cada futbolista.
model PlayerCompetition {
  playerId      Int    @map("player_id")
  competitionId String @map("competition_id")
  seasons       Int?
  matches       Int?
  goals         Int?
  assists       Int?
  firstSeason   Int?   @map("first_season")
  lastSeason    Int?   @map("last_season")

  player      FutPlayer   @relation(fields: [playerId], references: [playerId])
  competition Competition @relation(fields: [competitionId], references: [competitionId])

  @@id([playerId, competitionId])
  @@index([competitionId])
  @@map("player_competitions")
}

model PlayerNationalTeam {
  playerId       Int  @map("player_id")
  nationalTeamId Int  @map("national_team_id")
  caps           Int?
  goals          Int?

  player       FutPlayer    @relation(fields: [playerId], references: [playerId])
  nationalTeam NationalTeam @relation(fields: [nationalTeamId], references: [nationalTeamId])

  @@id([playerId, nationalTeamId])
  @@map("player_national_teams")
}

model Transfer {
  id               BigInt    @id @default(autoincrement())
  playerId         Int?      @map("player_id")
  transferDate     DateTime? @map("transfer_date") @db.Date
  transferSeason   String?   @map("transfer_season")
  fromClubId       Int?      @map("from_club_id")
  toClubId         Int?      @map("to_club_id")
  fromClubName     String?   @map("from_club_name")
  toClubName       String?   @map("to_club_name")
  transferFee      Decimal?  @map("transfer_fee")
  marketValueInEur Decimal?  @map("market_value_in_eur")
  playerName       String?   @map("player_name")

  player FutPlayer? @relation(fields: [playerId], references: [playerId])

  @@index([playerId])
  @@map("transfers")
}

model AwardWinner {
  awardId    Int     @map("award_id")
  year       Int
  playerName String? @map("player_name")
  /// null para ganadores históricos retirados que no están en `players`
  playerId   Int?    @map("player_id")

  award  Award      @relation(fields: [awardId], references: [awardId])
  player FutPlayer? @relation(fields: [playerId], references: [playerId])

  @@id([awardId, year])
  @@map("award_winners")
}

model TrophyWinner {
  trophyId   Int     @map("trophy_id")
  year       Int
  /// club o selección
  winnerName String? @map("winner_name")
  clubId     Int?    @map("club_id")

  trophy Trophy   @relation(fields: [trophyId], references: [trophyId])
  club   FutClub? @relation(fields: [clubId], references: [clubId])

  @@id([trophyId, year])
  @@map("trophy_winners")
}
