generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Game {
  id                    Int      @id
  name                  String
  description           String
  imageUrl              String
  availableDifficulties String[]

  matchRooms MatchRoom[]
}

/// The three kinds of unlockable cosmetic ("card", à la Clash Royale).
enum CollectibleKind {
  CREST // escudo de club
  AVATAR // avatar / caricatura del presidente
  STADIUM // estadio

  @@map("collectible_kind")
}

/// Rarity tier — drives the badge shown in the store.
enum Rarity {
  LEGEND
  EPIC
  RARE
  COMMON

  @@map("rarity")
}

/// A league level in the "Ruta de Ligas" (like a Clash Royale arena). The
/// player ascends through leagues as their club's market value grows, and each
/// league unlocks the collectibles tied to it.
model League {
  id          String @id @default(cuid())
  /// Short stable slug, e.g. "pe", "ar". Used by the UI and flag symbols.
  code        String @unique
  name        String
  /// Display country name, e.g. "Perú".
  country     String
  /// ISO-ish flag code used by the flag symbol sheet, e.g. "pe", "gb".
  countryCode String @map("country_code")
  imageUrl    String @map("image_url")
  /// 1-based progression order (1 = first/lowest league).
  tier        Int    @unique
  /// Market value (€M) the club must reach to enter this league.
  minMarketValue Int  @map("min_market_value")
  /// Market value (€M) at which the club ascends to the next league. Null for
  /// the top league (no ceiling).
  maxMarketValue Int? @map("max_market_value")

  createdAt DateTime @default(now()) @map("created_at")

  collectibles Collectible[]
  profiles     Profile[]

  @@map("leagues")
}

/// A signed-in player ("president"). Mirrors the Supabase `profiles` table
/// (rows are created by the `on_auth_user_created` trigger; `id` references
/// `auth.users`). Related to the league the club currently competes in.
model Profile {
  id            String   @id @db.Uuid
  presidentName String?  @map("president_name")
  country       String?
  avatarId      String?  @map("avatar_id")
  stadiumId     String?  @map("stadium_id")
  shieldId      String?  @map("shield_id")
  /// The club's value (€M) — drives league progression only.
  clubValue     Int      @default(0) @map("club_value")
  /// Spendable budget (€M) used to buy collectibles in the Mercado.
  clubFunds     Int      @default(0) @map("club_funds")
  budget        Int      @default(0)
  /// Career stats shown on the player card (lobby / club / friend cards).
  /// Updated later when the match system exists; start at sensible defaults.
  level         Int      @default(1)
  power         Int      @default(50)
  wins          Int      @default(0)
  played        Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @map("updated_at")

  leagueId String? @map("league_id")
  league   League? @relation(fields: [leagueId], references: [id], onDelete: SetNull)

  /// Every collectible this player owns (their "colección"). The avatarId /
  /// stadiumId / shieldId above point to the one of each kind currently active.
  owned OwnedCollectible[]

  /// Friendships and friend requests (social graph).
  sentRequests     FriendRequest[] @relation("SentRequests")
  receivedRequests FriendRequest[] @relation("ReceivedRequests")
  friendshipsA     Friendship[]    @relation("FriendshipsA")
  friendshipsB     Friendship[]    @relation("FriendshipsB")

  /// Friendly-match rooms and invites.
  hostedRooms         MatchRoom[]   @relation("HostedRooms")
  joinedRooms         MatchRoom[]   @relation("JoinedRooms")
  sentMatchInvites    MatchInvite[] @relation("SentMatchInvites")
  receivedMatchInvites MatchInvite[] @relation("ReceivedMatchInvites")

  @@index([leagueId])
  @@map("profiles")
}

/// A cosmetic the player can unlock/buy in the Mercado. Becomes available once
/// the player reaches the league it belongs to. Starter collectibles are also
/// offered during first-login profile setup.
model Collectible {
  id          String          @id @default(cuid())
  kind        CollectibleKind
  name        String
  /// Maps to a built-in vector art / CSS modifier (e.g. "veteran", "crest-rma",
  /// "coliseo"). Null when the art is a raster image instead.
  artKey      String?         @map("art_key")
  /// Optional raster image (e.g. a stadium photo).
  imageUrl    String?         @map("image_url")
  /// Optional 2-stop gradient for generated tiles (stadiums without a photo).
  gradientFrom String?        @map("gradient_from")
  gradientTo   String?        @map("gradient_to")
  rarity      Rarity          @default(COMMON)
  /// Price in coins. 0 = free starter pick.
  price       Int             @default(0)
  /// Whether this is offered as an option during first-login profile setup.
  isStarter   Boolean         @default(false) @map("is_starter")
  /// Ordering within its (league, kind) group.
  sortOrder   Int             @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  leagueId String @map("league_id")
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  owners OwnedCollectible[]

  @@index([leagueId])
  @@index([kind])
  @@map("collectibles")
}

/// Ownership ledger: which collectibles a player has acquired (bought in the
/// Mercado or granted as free starter picks during profile setup). Separate
/// from "equipped" — a player owns many of each kind but only one is active
/// (Profile.avatarId / stadiumId / shieldId).
model OwnedCollectible {
  id            String   @id @default(cuid())
  profileId     String   @map("profile_id") @db.Uuid
  collectibleId String   @map("collectible_id")
  acquiredAt    DateTime @default(now()) @map("acquired_at")

  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  collectible Collectible @relation(fields: [collectibleId], references: [id], onDelete: Cascade)

  @@unique([profileId, collectibleId])
  @@index([profileId])
  @@map("owned_collectibles")
}

/// Lifecycle of a friendly-match room (lobby).
enum MatchRoomStatus {
  OPEN // waiting for a rival (seat free)
  READY // both seats taken — match found
  CLOSED // abandoned by the host / superseded

  @@map("match_room_status")
}

/// A persistent friendly-match room. Exactly two seats: the host (creator) and
/// one guest. Created when the host presses JUGAR on /amistoso; the short
/// `code` is the URL slug (/jugar/amistoso/ABC123) and the invite-link token.
/// Access is restricted to host + guest; a third player can only take the
/// guest seat while it is free (first click wins, claimed atomically).
model MatchRoom {
  id         String          @id @default(cuid())
  /// Short shareable code, e.g. "K7M2QF". Unique across all rooms.
  code       String          @unique
  status     MatchRoomStatus @default(OPEN)
  /// Minigame + difficulty chosen by the host on /amistoso.
  gameId     Int?            @map("game_id")
  difficulty String?
  hostId     String          @map("host_id") @db.Uuid
  guestId    String?         @map("guest_id") @db.Uuid
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @default(now()) @map("updated_at")

  game  Game?    @relation(fields: [gameId], references: [id], onDelete: SetNull)
  host  Profile  @relation("HostedRooms", fields: [hostId], references: [id], onDelete: Cascade)
  guest Profile? @relation("JoinedRooms", fields: [guestId], references: [id], onDelete: SetNull)

  invites MatchInvite[]

  @@index([hostId, status])
  @@index([guestId])
  @@map("match_rooms")
}

/// Lifecycle of a match invite (room owner → friend).
enum MatchInviteStatus {
  PENDING
  ACCEPTED
  DECLINED // receiver pressed ✗
  CANCELLED // sender pressed X
  EXPIRED // seat taken by someone else / room closed

  @@map("match_invite_status")
}

/// An invitation to join a match room, sent by the host to a friend. Both
/// sides render it as a floating notification in real time (Postgres Changes).
/// One row per (room, receiver); re-inviting revives a declined row.
model MatchInvite {
  id          String            @id @default(cuid())
  roomId      String            @map("room_id")
  senderId    String            @map("sender_id") @db.Uuid
  receiverId  String            @map("receiver_id") @db.Uuid
  status      MatchInviteStatus @default(PENDING)
  createdAt   DateTime          @default(now()) @map("created_at")
  respondedAt DateTime?         @map("responded_at")

  room     MatchRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender   Profile   @relation("SentMatchInvites", fields: [senderId], references: [id], onDelete: Cascade)
  receiver Profile   @relation("ReceivedMatchInvites", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([roomId, receiverId])
  @@index([receiverId, status])
  @@index([senderId, status])
  @@map("match_invites")
}

/// Lifecycle of a friend request between two presidents.
enum FriendRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED

  @@map("friend_request_status")
}

/// A pending/resolved friend request. One direction (sender → receiver).
/// Becomes a Friendship row once accepted.
model FriendRequest {
  id          String              @id @default(cuid())
  senderId    String              @map("sender_id") @db.Uuid
  receiverId  String              @map("receiver_id") @db.Uuid
  status      FriendRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now()) @map("created_at")
  respondedAt DateTime?           @map("responded_at")

  sender   Profile @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver Profile @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@map("friend_requests")
}

/// An accepted friendship, stored once with a canonical ordering
/// (userAId < userBId) so a pair never appears twice.
model Friendship {
  id        String   @id @default(cuid())
  userAId   String   @map("user_a_id") @db.Uuid
  userBId   String   @map("user_b_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  userA Profile @relation("FriendshipsA", fields: [userAId], references: [id], onDelete: Cascade)
  userB Profile @relation("FriendshipsB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userBId])
  @@map("friendships")
}
